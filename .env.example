# ────────────────────────────────────────────────────────────────
#  Vault Music PWA — Environment Variables
# ────────────────────────────────────────────────────────────────

# Backend API URL (Node.js + Fastify server)
# 
# For local development:
#   VITE_API_URL=http://localhost:3001
#
# For iPhone testing on the same network:
#   1. Find your machine's local IP: `ifconfig | grep inet` (macOS/Linux)
#                                     or `ipconfig` (Windows)
#   2. Set: VITE_API_URL=http://192.168.1.XXX:3001
#      (replace XXX with your actual IP's last segment)
#
# Leave blank for DEMO MODE (uses static mock data):
#   VITE_API_URL=

VITE_API_URL=http://localhost:3001
