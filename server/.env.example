# ─────────────────────────────────────────────────────────────
#  Vault Music Server — Environment Variables
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────
PORT=3001

# ── Database ──────────────────────────────────────────────────
# Path is relative to server/prisma/ directory
DATABASE_URL="file:./dev.db"

# ── Music Library ─────────────────────────────────────────────
# Absolute path OR path relative to where you run the server from.
# This directory is scanned recursively for MP3, FLAC, M4A, etc.
MUSIC_DIR="/path/to/your/music"

# ── Environment ───────────────────────────────────────────────
NODE_ENV=development

# ─────────────────────────────────────────────────────────────
#  Frontend (.env in the root Vite project)
#  Add this line to your root .env so the React app hits this server:
#    VITE_API_URL=http://192.168.1.YOUR_IP:3001
#  (Use your local network IP if accessing from iPhone on Wi-Fi)
# ─────────────────────────────────────────────────────────────
